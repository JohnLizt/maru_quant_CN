# ─────────────────────────────────────────────────────────────
# A股量化系统 - 环境变量配置
# 复制为 .env 并按需修改
# cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── TimescaleDB ──────────────────────────────────────────────
POSTGRES_USER=quant
POSTGRES_PASSWORD=quantpass_change_me
POSTGRES_DB=quant_db
TIMESCALEDB_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=redispass_change_me
REDIS_PORT=6379

# ── JupyterLab ───────────────────────────────────────────────
JUPYTER_TOKEN=quanttoken_change_me
JUPYTER_PORT=8888

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafanapass_change_me
GRAFANA_PORT=3000

# ── Tushare ──────────────────────────────────────────────────
TUSHARE_TOKEN=your_token_here
